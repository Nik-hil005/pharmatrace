# --- Dependencies ---
node_modules/

# --- Environment & secrets (never commit real secrets) ---
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key

# --- Logs & debug ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Build & bundler output ---
dist/
build/
out/
.vite/
*.tsbuildinfo

# --- Test & coverage ---
coverage/
.nyc_output/
*.lcov

# --- Caches ---
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.cache

# --- OS ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- Editors & IDEs ---
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# VS Code — ignore user-local; commit shared snippets/tasks if your team uses them
.vscode/*
!.vscode/extensions.json

# --- Temp & scratch ---
*.tmp
*.temp
*.swp
*~
*.orig
*.rej

# --- Runtime / misc ---
pids/
*.pid
*.seed
*.pid.lock

# --- Database dumps & local DB files ---
*.sql.backup
*.dump
*.db
*.sqlite
*.sqlite3

# --- Python (optional tooling / scripts) ---
__pycache__/
*.py[cod]
.Python
venv/
.venv/

# --- Misc ---
*.local
